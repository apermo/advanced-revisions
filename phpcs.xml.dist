<?xml version="1.0"?>
<ruleset xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    name="advanced-revisions"
    xsi:noNamespaceSchemaLocation="https://raw.githubusercontent.com/PHPCSStandards/PHP_CodeSniffer/master/phpcs.xsd">

    <description>PHPCS configuration for advanced-revisions.</description>

    <file>.</file>
    <exclude-pattern>.ddev/*</exclude-pattern>
    <exclude-pattern>vendor/*</exclude-pattern>
    <exclude-pattern>node_modules/*</exclude-pattern>

    <arg name="extensions" value="php"/>

    <rule ref="Apermo"/>

    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="advanced-revisions"/>
            </property>
        </properties>
    </rule>

    <!--
        Project prefix for global functions, hooks, constants,
        and namespace roots. E.g. prefix "AdvancedRevisions" allows
        namespace AdvancedRevisions\Admin but flags Other\Admin.
    -->
    <rule ref="WordPress.NamingConventions.PrefixAllGlobals">
        <properties>
            <property name="prefixes" type="array">
                <element value="Apermo\AdvancedRevisions"/>
                <element value="advanced_revisions"/>
            </property>
        </properties>
        <!-- Test bootstrap uses standard WP test globals, not plugin globals. -->
        <exclude-pattern>tests/bootstrap.php</exclude-pattern>
    </rule>

    <!-- Test fixtures legitimately need many-key arrays (options, mock payloads). -->
    <rule ref="Apermo.DataStructures.ArrayComplexity.TooManyKeys">
        <exclude-pattern>*/tests/*</exclude-pattern>
    </rule>

    <rule ref="Apermo.NamingConventions.MinimumVariableNameLength">
        <properties>
            <property name="allowedShortNames" type="array">
                <element value="i"/>
                <element value="id"/>
                <element value="ids"/>
                <element value="a"/>
                <element value="b"/>
                <element value="key"/>
                <element value="min"/>
                <element value="max"/>
                <element value="rng"/>
            </property>
        </properties>
    </rule>

    <config name="minimum_wp_version" value="6.4"/>
</ruleset>
